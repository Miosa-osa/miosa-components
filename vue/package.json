{
  "name": "@miosa/vue",
  "version": "0.3.0",
  "description": "Vue 3 components for MIOSA sandbox infrastructure",
  "license": "MIT",
  "author": "MIOSA <hello@miosa.ai>",
  "homepage": "https://miosa.ai",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "xterm": {
      "optional": true
    },
    "monaco-editor": {
      "optional": true
    }
  },
  "devDependencies": {
    "@miosa/sdk": "^1.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
